{
  "name": "mini-EzCala",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r requirements.txt && python -m app.seed_data",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "mini-EzCala API", "onAutoForward": "openPreview" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
